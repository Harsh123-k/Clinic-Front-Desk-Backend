{
  "info": {
    "_postman_id": "8c5eb3c0-435e-4a6f-b25c-02cf3c94d03e",
    "name": "Clinic Front Desk Management System - Phase 1",
    "description": "Postman Collection for Phase 1 APIs including User Login and Patient CRUD management with RBAC support.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Admin",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clinic.com\",\n  \"password\": \"Admin@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Log in as the default Admin to obtain a JWT token. Copy the token returned and paste it into the authorization/token variable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Patient Management",
      "item": [
        {
          "name": "Create Patient",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"gender\": \"Male\",\n  \"dob\": \"1990-05-15\",\n  \"bloodGroup\": \"O+\",\n  \"phone\": \"9998887776\",\n  \"email\": \"john.doe@example.com\",\n  \"address\": \"123 Health Ave, Medical District\",\n  \"emergencyContact\": {\n    \"name\": \"Jane Doe\",\n    \"relationship\": \"Spouse\",\n    \"phone\": \"9876543210\"\n  },\n  \"allergies\": [\"Penicillin\", \"Peanuts\"],\n  \"medicalHistory\": [\"Hypertension\"],\n  \"currentMedication\": [\"Lisinopril 10mg\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients"
              ]
            },
            "description": "Register a new patient. Accessible by Admin and Receptionist."
          },
          "response": []
        },
        {
          "name": "Get All Patients",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients?search=John&page=1&limit=10&sortBy=createdAt&sortOrder=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "John",
                  "description": "Optional search term for patientId, name, phone, or email"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Limit per page"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt",
                  "description": "Field to sort by"
                },
                {
                  "key": "sortOrder",
                  "value": "desc",
                  "description": "Sort order (asc/desc)"
                }
              ]
            },
            "description": "Retrieve all patients with optional search query, pagination, and sorting parameters. Accessible by Admin, Receptionist, and Doctor."
          },
          "response": []
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients/{{patientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients",
                "{{patientId}}"
              ]
            },
            "description": "Retrieve patient by database object ID. Accessible by Admin, Receptionist, and Doctor."
          },
          "response": []
        },
        {
          "name": "Update Patient",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John Updated\",\n  \"lastName\": \"Doe\",\n  \"gender\": \"Male\",\n  \"dob\": \"1990-05-15\",\n  \"bloodGroup\": \"O-\",\n  \"phone\": \"9998887777\",\n  \"email\": \"john.doe.updated@example.com\",\n  \"address\": \"456 Wellness Way\",\n  \"emergencyContact\": {\n    \"name\": \"Jane Doe\",\n    \"relationship\": \"Spouse\",\n    \"phone\": \"9876543210\"\n  },\n  \"allergies\": [\"Penicillin\"],\n  \"medicalHistory\": [\"Hypertension\", \"Type 2 Diabetes\"],\n  \"currentMedication\": [\"Lisinopril 10mg\", \"Metformin 500mg\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/patients/{{patientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients",
                "{{patientId}}"
              ]
            },
            "description": "Update details of an existing patient. Accessible by Admin and Receptionist."
          },
          "response": []
        },
        {
          "name": "Delete Patient",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients/{{patientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients",
                "{{patientId}}"
              ]
            },
            "description": "Delete a patient record by ID. Accessible by Admin only."
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "patientId",
      "value": "patient_mongodb_id_here",
      "type": "string"
    }
  ]
